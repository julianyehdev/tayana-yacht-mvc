<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
<meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
<title>@ViewBag.Title — Tayana Yacht</title>
<script type="text/javascript" src="@Url.Content("~/Scripts/vendor/jquery.min.js")"></script>
<script type="text/javascript" src="@Url.Content("~/Scripts/vendor/jquery.cycle.all.2.74.js")"></script>
<!--[if lt IE 7]>
<script type="text/javascript" src="@Url.Content("~/Scripts/javascript/iepngfix_tilebg.js")"></script>
<![endif]-->
<link href="@Url.Content("~/Content/css/" + (ViewBag.MainCss ?? "homestyle.css"))" rel="stylesheet" type="text/css" />
<link href="@Url.Content("~/Content/css/reset.css")" rel="stylesheet" type="text/css" />
<style>
  .alert {
    position: fixed;
    bottom: 20px;
    right: 20px;
    width: 350px;
    margin: 0;
    z-index: 9999;
    animation: slideIn 0.3s ease-out;
  }

  @@keyframes slideIn {
    from {
      transform: translateX(400px);
      opacity: 0;
    }
    to {
      transform: translateX(0);
      opacity: 1;
    }
  }

  .btn-close {
    width: 1em;
    height: 1em;
    background: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='%23000' d='M.293.293a1 1 0 011.414 0L8 6.586 14.293.293a1 1 0 111.414 1.414L9.414 8l6.293 6.293a1 1 0 01-1.414 1.414L8 9.414l-6.293 6.293a1 1 0 01-1.414-1.414L6.586 8 .293 1.707a1 1 0 010-1.414z'/%3e%3c/svg%3e") center / 1em auto no-repeat;
    border: 0;
    cursor: pointer;
    padding: 0;
    opacity: 0.5;
  }
  .btn-close:hover {
    opacity: 0.75;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const alerts = document.querySelectorAll('.alert');
    alerts.forEach(function(alert) {
      setTimeout(function() {
        const bsAlert = new bootstrap.Alert(alert);
        bsAlert.close();
      }, 3000);
    });
  });
</script>
</head>

<body>
<div class="contain">
  <div class="sub"><p><a href="@Url.Action("Index", "Home")">Home</a></p></div>

<!--------------------------------選單開始---------------------------------------------------->
  <div class="menu">
  <ul>
  <li class="menuli01"><a href="@Url.Action("Overview", "Yacht")">Yachts</a></li>
  <li class="menuli02"><a href="@Url.Action("Index", "News")">NEWS</a></li>
  <li class="menuli03"><a href="@Url.Action("AboutUs", "Company")">COMPANY</a></li>
  <li class="menuli04"><a href="@Url.Action("Index", "Dealer")">DEALERS</a></li>
  <li class="menuli05"><a href="@Url.Action("Index", "Contact")">CONTACT</a></li>
  </ul>
  </div>
<!--------------------------------選單結束---------------------------------------------------->

    @RenderBody()

