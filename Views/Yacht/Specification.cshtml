@model TayanaYachtMVC.Models.Domain.Yacht

@{
    Layout = "~/Views/Shared/_FrontLayout.cshtml";
    ViewBag.Title = Model.YachtName + " — Specification";
}

<!--遮罩-->
<div class="bannermasks"><img src="@Url.Content("~/img/banners/banner01_masks.png")" alt="" /></div>
<!--遮罩結束-->

<div id="buttom01"><a href="#"><img src="@Url.Content("~/img/icons/buttom01.gif")" alt="next" /></a></div>

<!--小圖開始-->
<div class="bannerimg">
@{
    var photos = Model.YachtPhotos?.OrderBy(p => p.SortOrder).Take(8).ToList() ?? new List<TayanaYachtMVC.Models.Domain.YachtPhoto>();
}
<ul>
@for (int i = 0; i < photos.Count; i++)
{
    <li>
        <a href="#">
            @if (i == 0)
            {
                <div class="on"><p class="bannerimg_p"><img src="@Url.Content("~/" + photos[i].PhotoUrl)" alt="" width="99" height="59" /></p></div>
            }
            else
            {
                <p class="bannerimg_p"><img src="@Url.Content("~/" + photos[i].PhotoUrl)" alt="" width="99" height="59" /></p>
            }
        </a>
    </li>
}
</ul>

<ul>
@for (int i = 0; i < photos.Count; i++)
{
    <li>
        @if (i == 0)
        {
            <a class="on" href="#"><p class="bannerimg_p"><img src="@Url.Content("~/" + photos[i].PhotoUrl)" alt="" width="99" height="59" /></p></a>
        }
        else
        {
            <p class="bannerimg_p"><a href="#"><img src="@Url.Content("~/" + photos[i].PhotoUrl)" alt="" width="99" height="59" /></a></p>
        }
    </li>
}
</ul>
</div>
<!--小圖結束-->

<div id="buttom02"><a href="#"><img src="@Url.Content("~/img/icons/buttom02.gif")" alt="next" /></a></div>

<!--換圖開始-->
<div class="banner">
<ul>
@{
    var allPhotos = Model.YachtPhotos?.OrderBy(p => p.SortOrder).ToList() ?? new List<TayanaYachtMVC.Models.Domain.YachtPhoto>();
}
@foreach (var photo in allPhotos)
{
    <li><img src="@Url.Content("~/" + photo.PhotoUrl)" /></li>
}
</ul>
</div>
<!--換圖結束-->

<div class="conbg">
<!--左邊選單開始-->
<div class="left">
<div class="left1">
<p><span>YACHTS</span></p>
<ul>
@{
    var allYachts = ViewBag.AllYachts as List<TayanaYachtMVC.Models.Domain.Yacht> ?? new List<TayanaYachtMVC.Models.Domain.Yacht>();
}
@foreach (var y in allYachts)
{
    var displayName = string.IsNullOrEmpty(y.ModelNumber) ? y.YachtName : $"{y.YachtName} {y.ModelNumber}";
    <li><a href="@Url.Action("Specification", "Yacht", new { yachtName = y.YachtName, modelNumber = y.ModelNumber })">@displayName</a></li>
}
</ul>
</div>
</div>
<!--左邊選單結束-->

<!--右邊內容開始-->
<div id="crumb"><a href="@Url.Action("Index", "Home")">Home</a> &gt;&gt; <a href="@Url.Action("Overview", "Yacht")">Yachts</a> &gt;&gt; <a href="#"><span class="on1">@Model.YachtName</span></a></div>
<div class="right">
<div class="right1">
  <div class="title"><span>@Model.YachtName @Model.ModelNumber</span></div>

<!--次選單-->
<div class="menu_y">
<ul>
<li class="menu_y00">YACHTS</li>
<li><a class="menu_yli01" href="@Url.Action("Overview", "Yacht")">Interior</a></li>
<li><a class="menu_yli02" href="@Url.Action("DeckPlan", "Yacht")">Layout &amp; deck plan</a></li>
<li><a class="menu_yli03" href="@Url.Action("Specification", "Yacht")">Specification</a></li>
</ul>
</div>
<!--次選單結束-->

<div class="box5">
<h4>DETAIL SPECIFICATION</h4>
@Html.Raw(Model.DetailSpecification)
</div>

<p class="topbuttom" style="cursor: pointer;"><img src="@Url.Content("~/img/icons/top.gif")" alt="top" /></p>

</div>
</div>
<!--右邊內容結束-->
</div>

@section scripts {
<script type="text/javascript">
$(document).ready(function() {
    $('.banner ul').cycle({
        fx: 'fade',
        speed: 1000,
        timeout: 4000
    });

    $('.topbuttom').click(function() {
        $('html, body').animate({ scrollTop: 0 }, 'smooth');
    });
});
</script>
}
