@model TayanaYachtMVC.Models.Domain.Dealer

@{
    ViewBag.Title = "刪除經銷商";
}

<h3>確定要刪除此經銷商？</h3>
<div>
    <hr />

    <div class="row mb-3">
        <div class="col-md-3">
            <strong>@Html.DisplayNameFor(model => model.Name)</strong>
        </div>
        <div class="col-md-9">
            @Html.DisplayFor(model => model.Name)
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-3">
            <strong>國家</strong>
        </div>
        <div class="col-md-9">
            @(Model.Region?.Country?.CountryName ?? "-")
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-3">
            <strong>地區</strong>
        </div>
        <div class="col-md-9">
            @(Model.Region?.RegionName ?? "-")
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-3">
            <strong>@Html.DisplayNameFor(model => model.IsPublished)</strong>
        </div>
        <div class="col-md-9">
            @Html.DisplayFor(model => model.IsPublished)
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-3">
            <strong>@Html.DisplayNameFor(model => model.SortOrder)</strong>
        </div>
        <div class="col-md-9">
            @Html.DisplayFor(model => model.SortOrder)
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.MainImageUrl))
    {
        <div class="row mb-3">
            <div class="col-md-3">
                <strong>@Html.DisplayNameFor(model => model.MainImageUrl)</strong>
            </div>
            <div class="col-md-9">
                <img src="@Url.Content(Model.MainImageUrl)" alt="@Model.Name" style="max-width:200px; max-height:150px; object-fit:cover; border-radius:4px;" />
                <br /><small class="text-muted">刪除後圖片實體檔案將一併移除</small>
            </div>
        </div>
    }

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()

        <div class="form-group">
            <div class="col-md-offset-2 col-md-10">
                <input type="submit" value="刪除" class="btn btn-danger" />
                @Html.ActionLink("回列表", "Index", null, new { @class = "btn btn-secondary ms-2" })
            </div>
        </div>
    }
</div>
