@model TayanaYachtMVC.Models.Domain.Dealer

@{
    ViewBag.Title = "刪除經銷商";
}

<h4>確定要刪除此經銷商？</h4>
<hr />

<dl class="dl-horizontal">
    <dt>@Html.DisplayNameFor(model => model.Name)</dt>
    <dd>@Html.DisplayFor(model => model.Name)</dd>

    <dt>國家</dt>
    <dd>@(Model.Region?.Country?.CountryName ?? "-")</dd>

    <dt>地區</dt>
    <dd>@(Model.Region?.RegionName ?? "-")</dd>

    <dt>@Html.DisplayNameFor(model => model.IsPublished)</dt>
    <dd>@Html.DisplayFor(model => model.IsPublished)</dd>

    <dt>@Html.DisplayNameFor(model => model.SortOrder)</dt>
    <dd>@Html.DisplayFor(model => model.SortOrder)</dd>

    @if (!string.IsNullOrEmpty(Model.MainImageUrl))
    {
        <dt>@Html.DisplayNameFor(model => model.MainImageUrl)</dt>
        <dd>
            <img src="@Url.Content(Model.MainImageUrl)" alt="@Model.Name" style="max-width:200px; max-height:150px; object-fit:cover; border-radius:4px;" />
            <br /><small class="text-muted">刪除後圖片實體檔案將一併移除</small>
        </dd>
    }
</dl>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    <input type="submit" value="確認刪除" class="btn btn-danger" />
    @Html.ActionLink("取消", "Index", null, new { @class = "btn btn-secondary ms-2" })
}
