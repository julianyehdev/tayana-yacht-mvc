@model TayanaYachtMVC.Models.Domain.Yacht

@{
    ViewBag.Title = "編輯遊艇";
}

@using (Html.BeginForm("Edit", "Yachts", FormMethod.Post, new { enctype = "multipart/form-data", id = "edit-yacht-form" }))
{
    @Html.AntiForgeryToken()

    <div class="form-horizontal">
        <h4>Yacht</h4>
        <hr />
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })
        @Html.HiddenFor(model => model.YachtID)

        <div class="form-group">
            @Html.LabelFor(model => model.YachtName, htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.EditorFor(model => model.YachtName, new { htmlAttributes = new { @class = "form-control" } })
                @Html.ValidationMessageFor(model => model.YachtName, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            <div class="col-md-offset-2 col-md-10">
                <label style="font-weight:normal;">
                    是否為最新款 @Html.CheckBoxFor(model => model.IsLatest)
                </label>
            </div>
        </div>


        @* ── 輪播圖相簿 ── *@
        <div class="form-group">
            <label class="control-label col-md-2">輪播圖相簿</label>
            <div class="col-md-10">
                <div style="border:1px solid #d0d0d0; border-radius:6px; padding:16px; background:#fff;">

                    @* 上傳區（點擊或拖曳） *@
                    <div id="drop-zone" style="border:2px dashed #007bff; border-radius:8px; padding:40px; text-align:center; background:#f8fbff; cursor:pointer; margin-bottom:15px;">
                        <p style="margin:0; color:#007bff; font-weight:bold;">＋ 點擊或拖曳圖片至此上傳</p>
                        <p style="font-size:0.8em; color:#666; margin-top:8px;">支援 JPG, PNG, WEBP（單檔最大 5MB）</p>
                        <input type="file" id="photo-file-input" multiple accept="image/jpeg,image/png,image/webp" style="display:none;" />
                    </div>

                    @* 統一 grid：現有圖片 + 新上傳圖片都在這裡 *@
                    <div id="photo-preview-list" style="display:grid; grid-template-columns:repeat(auto-fill,minmax(150px,1fr)); gap:15px; min-height:80px; padding:12px; border:2px dashed #ccc; border-radius:6px; background:#f5f5f5;">
                        @* 現有圖片由 Razor 直接渲染進 grid *@
                        @if (Model.YachtPhotos != null)
                        {
                            foreach (var photo in Model.YachtPhotos.OrderBy(p => p.SortOrder))
                            {
                                <div class="existing-photo-card" data-photo-id="@photo.PhotoID"
                                     style="position:relative; border:2px solid #ddd; border-radius:6px; overflow:hidden; background:#fff; cursor:grab;">
                                    <img src="@Url.Content(photo.PhotoUrl)" style="width:100%; height:120px; object-fit:cover;" />
                                    <div class="sort-num" style="position:absolute;top:4px;left:4px;background:rgba(0,0,0,0.5);color:#fff;border-radius:50%;width:22px;height:22px;text-align:center;line-height:22px;font-size:12px;"></div>
                                    <button type="button" class="btn btn-danger btn-xs"
                                            onclick="markDeletePhoto(this, @photo.PhotoID)"
                                            style="position:absolute; top:4px; right:4px;">✕</button>
                                    <input type="hidden" class="delete-photo-input" value="@photo.PhotoID" disabled />
                                </div>
                            }
                        }
                    </div>

                    <div id="photo-sort-order-inputs"></div>
                    <input type="file" name="photos" multiple id="actual-photos-input" style="display:none;" />
                    <small class="text-muted" style="margin-top:8px; display:block;">可拖曳調整順序，第 1 張為輪播封面｜點擊 ✕ 標記刪除（儲存後生效）</small>
                </div>
            </div>
        </div>

        <div class="form-group">
            <div class="col-md-offset-2 col-md-10">
                <input type="submit" value="儲存" class="btn btn-default" />
            </div>
        </div>
    </div>
}

<div>
    @Html.ActionLink("回列表", "Index")
</div>

@* SortableJS：讓新上傳預覽列表支援拖曳排序 *@
<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
<script>
    // ==================== 標記刪除現有照片 ====================
    // 點擊 ✕ 後，將卡片半透明標示，並啟用隱藏 input 讓表單送出該 PhotoID
    function markDeletePhoto(btn, photoId) {
        var card = btn.closest('.existing-photo-card');
        var input = card.querySelector('.delete-photo-input');
        if (input.disabled) {
            // 標記刪除
            input.disabled = false;
            input.name = 'deletePhotoIds';
            card.style.opacity = '0.35';
            btn.textContent = '↩';
            btn.classList.remove('btn-danger');
            btn.classList.add('btn-secondary');
        } else {
            // 取消標記
            input.disabled = true;
            input.name = '';
            card.style.opacity = '1';
            btn.textContent = '✕';
            btn.classList.remove('btn-secondary');
            btn.classList.add('btn-danger');
        }
    }

    // ==================== 新圖上傳模組 ====================
    var photoFiles = [];

    var dropZone = document.getElementById('drop-zone');
    var fileInput = document.getElementById('photo-file-input');
    var previewList = document.getElementById('photo-preview-list');
    var actualInput = document.getElementById('actual-photos-input');

    dropZone.addEventListener('click', function () { fileInput.click(); });

    dropZone.addEventListener('dragover', function (e) {
        e.preventDefault();
        dropZone.style.background = '#e8f4ff';
    });
    dropZone.addEventListener('dragleave', function () {
        dropZone.style.background = '#f8fbff';
    });
    dropZone.addEventListener('drop', function (e) {
        e.preventDefault();
        dropZone.style.background = '#f8fbff';
        addFiles(e.dataTransfer.files);
    });

    fileInput.addEventListener('change', function () {
        addFiles(this.files);
        this.value = '';
    });

    function addFiles(files) {
        Array.from(files).forEach(function (file) {
            if (!file.type.match('image/(jpeg|png|webp)')) return;
            if (file.size > 5 * 1024 * 1024) { alert(file.name + ' 超過 5MB，已略過'); return; }
            photoFiles.push(file);
            renderPreview(file, photoFiles.length - 1);
        });
        syncActualInput();
    }

    function renderPreview(file, index) {
        var reader = new FileReader();
        reader.onload = function (e) {
            var card = document.createElement('div');
            card.className = 'photo-card';
            card.dataset.index = index;
            card.style.cssText = 'position:relative; border:2px solid #ddd; border-radius:6px; overflow:hidden; background:#fff; cursor:grab;';
            card.innerHTML =
                '<img src="' + e.target.result + '" style="width:100%; height:120px; object-fit:cover;" />' +
                '<div style="position:absolute;top:4px;left:4px;background:rgba(0,0,0,0.5);color:#fff;border-radius:50%;width:22px;height:22px;text-align:center;line-height:22px;font-size:12px;" class="sort-num"></div>' +
                '<button type="button" onclick="removePhoto(this)" style="position:absolute;top:4px;right:4px;" class="btn btn-danger btn-xs">✕</button>';
            previewList.appendChild(card);
            updateSortNumbers();
        };
        reader.readAsDataURL(file);
    }

    function removePhoto(btn) {
        var card = btn.closest('.photo-card');
        var idx = parseInt(card.dataset.index);
        photoFiles[idx] = null;
        card.remove();
        updateSortNumbers();
        syncActualInput();
    }

    function updateSortNumbers() {
        // 涵蓋現有圖片（.existing-photo-card）和新上傳（.photo-card），依 DOM 順序編號
        var cards = previewList.querySelectorAll('.existing-photo-card, .photo-card');
        cards.forEach(function (card, i) { card.querySelector('.sort-num').textContent = i + 1; });
    }

    // 頁面載入時，對現有圖片初始化排序數字
    updateSortNumbers();

    function syncActualInput() {
        var dt = new DataTransfer();
        photoFiles.filter(Boolean).forEach(function (f) { dt.items.add(f); });
        actualInput.files = dt.files;
    }

    // SortableJS 拖曳排序
    Sortable.create(previewList, {
        animation: 150,
        onEnd: function () {
            var cards = previewList.querySelectorAll('.photo-card');
            var reordered = [];
            cards.forEach(function (card) {
                var idx = parseInt(card.dataset.index);
                reordered.push(photoFiles[idx]);
            });
            photoFiles = reordered;
            cards.forEach(function (card, i) { card.dataset.index = i; });
            updateSortNumbers();
            syncActualInput();
        }
    });

    // 表單送出前，依 DOM 順序產生所有排序 hidden inputs
    document.getElementById('edit-yacht-form').addEventListener('submit', function () {
        var container = document.getElementById('photo-sort-order-inputs');
        container.innerHTML = '';

        // 取得 grid 中所有卡片（含現有圖片和新上傳），依視覺順序編號
        var allCards = previewList.querySelectorAll('.existing-photo-card, .photo-card');
        var newPhotoIndex = 0;

        allCards.forEach(function (card, i) {
            var sortOrder = i + 1;
            if (card.classList.contains('existing-photo-card')) {
                // 現有圖片：送出 photoId 對應新的 SortOrder
                var photoId = card.dataset.photoId;
                var idInput = document.createElement('input');
                idInput.type = 'hidden';
                idInput.name = 'existingPhotoOrder';
                idInput.value = photoId;
                container.appendChild(idInput);

                var orderInput = document.createElement('input');
                orderInput.type = 'hidden';
                orderInput.name = 'existingPhotoSortOrder';
                orderInput.value = sortOrder;
                container.appendChild(orderInput);
            } else {
                // 新上傳圖片：送出該張的新 SortOrder
                var input = document.createElement('input');
                input.type = 'hidden';
                input.name = 'photoSortOrders';
                input.value = sortOrder;
                container.appendChild(input);
                newPhotoIndex++;
            }
        });
    });
</script>
