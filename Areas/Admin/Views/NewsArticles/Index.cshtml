@using PagedList.Mvc
@model PagedList.IPagedList<TayanaYachtMVC.Models.Domain.NewsArticle>

@{
    ViewBag.Title = "新聞列表";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    @Html.ActionLink("新增新聞", "Create", null, new { @class = "btn btn-primary" })

    @using (Html.BeginForm("Index", "NewsArticles", FormMethod.Get, new { @class = "d-flex gap-2" }))
    {
        <input type="text" name="keyword" value="@ViewBag.Keyword" class="form-control" placeholder="搜尋標題..." />
        @Html.DropDownList("categoryId", (SelectList)ViewBag.CategoryId, "全部類別", new { @class = "form-select" })
        <button type="submit" class="btn btn-outline-secondary">搜尋</button>
        @Html.ActionLink("清空", "Index", null, new { @class = "btn btn-outline-danger" })
    }
</div>

<table class="table">
    <tr>
        <th>標題</th>
        <th>類別名稱</th>
        <th>發布日期</th>
        <th>已發布</th>
        <th>置頂</th>
        <th></th>
    </tr>

@foreach (var item in Model) {
    <tr>
        <td>@Html.ActionLink(item.Title, "Edit", new { id = item.Id })</td>
        <td>@Html.DisplayFor(modelItem => item.Category.Name)</td>
        <td>@Html.DisplayFor(modelItem => item.PublishDate)</td>
        <td>@Html.DisplayFor(modelItem => item.IsPublished)</td>
        <td>@Html.DisplayFor(modelItem => item.IsPinned)</td>
        <td>
            @Html.ActionLink("編輯", "Edit", new { id = item.Id }, new { @class = "btn btn-outline-primary btn-sm" })
            @Html.ActionLink("刪除", "Delete", new { id = item.Id }, new { @class = "btn btn-outline-danger btn-sm" })
        </td>
    </tr>
}

</table>

<div class="d-flex align-items-center gap-2 mt-3">
    每頁
    <select onchange="changePageSize(this.value)" class="form-select form-select-sm d-inline-block w-auto">
        @foreach (var s in new[] { 5, 10, 25, 50, 100 })
        {
            <option value="@s" @((Request.QueryString["pageSize"] ?? "10") == s.ToString() ? "selected" : "")>@s</option>
        }
    </select>
    筆，第 @Model.PageNumber / @Model.PageCount 頁，共 @Model.TotalItemCount 筆 &nbsp;|&nbsp;

    @if (Model.HasPreviousPage)
    {
        <a href="@Url.Action("Index", new { page = Model.PageNumber - 1, pageSize = Request.QueryString["pageSize"] ?? "10", keyword = ViewBag.Keyword, categoryId = ViewBag.CategoryIdValue })" class="btn btn-sm btn-outline-secondary">上一頁</a>
    }
    else
    {
        <button class="btn btn-sm btn-outline-secondary" disabled>上一頁</button>
    }

    &nbsp;| 跳至第
    <select onchange="jumpToPage(this.value)" class="form-select form-select-sm d-inline-block w-auto">
        @for (int i = 1; i <= Model.PageCount; i++)
        {
            <option value="@i" @(Model.PageNumber == i ? "selected" : "")>@i</option>
        }
    </select>
    頁 |&nbsp;

    @if (Model.HasNextPage)
    {
        <a href="@Url.Action("Index", new { page = Model.PageNumber + 1, pageSize = Request.QueryString["pageSize"] ?? "10", keyword = ViewBag.Keyword, categoryId = ViewBag.CategoryIdValue })" class="btn btn-sm btn-outline-secondary">下一頁</a>
    }
    else
    {
        <button class="btn btn-sm btn-outline-secondary" disabled>下一頁</button>
    }
</div>

<script>
    function changePageSize(size) {
        var url = new URL(window.location.href);
        url.searchParams.set('pageSize', size);
        url.searchParams.set('page', 1);
        window.location.href = url.toString();
    }
    function jumpToPage(p) {
        var url = new URL(window.location.href);
        url.searchParams.set('page', p);
        window.location.href = url.toString();
    }
</script>
